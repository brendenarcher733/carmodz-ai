ENVIRONMENT=development
DATABASE_URL=sqlite:///./carmods.db
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Job queue — backs the async recommendation worker (workers/recommendation_worker.py)
REDIS_URL=redis://localhost:6379

# REQUIRED in production — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# The app refuses to start with ENVIRONMENT=production if this is left at its dev default.
SECRET_KEY=

# The frontend's own URL — used to build links that go into verification/
# password-reset emails (those open in a browser pointed at the frontend).
FRONTEND_URL=http://localhost:5173

# Email — "mock" (default) logs the full message instead of sending it, same
# pattern as AI_PROVIDER=mock. Set EMAIL_PROVIDER=smtp + the vars below to
# actually send (works with Gmail, SendGrid, Postmark, SES, or anything else
# SMTP-capable).
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@carmods.ai
SMTP_USE_TLS=true

# Email-verification gating — both default to fully open (nothing blocked).
# See core/config.py / routers/auth.py's require_verified_email() for how
# these are meant to be used.
REQUIRE_EMAIL_VERIFICATION_TO_LOGIN=false
EMAIL_VERIFICATION_REQUIRED_FEATURES=
